{
    "compilerOptions": {
        "target": "ES6",
        "module": "NodeNext",
        "outDir": "./dist",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "moduleResolution": "NodeNext",
        "isolatedModules": true
    },
    "include": [
        "src/**/*",
        "public/src/ts/**/*"
    ]
}