{
    "compilerOptions": {
        "target": "ES6",
        "module": "ESNext",
        "moduleResolution": "node",
        "outDir": "../dist/js",
        "rootDir": "./src/ts",
        "strict": true,
        "composite": true,
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true,
    },
    "include": [
        "src/ts/**/*"
    ]
}